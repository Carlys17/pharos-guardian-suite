# Pharos Guardian Suite — Environment Variables

# === Pharos Network ===
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689
PHAROS_EXPLORER=https://atlantic.pharosscan.xyz

# === Wallet ===
# Your Pharos testnet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# === x402 Payment ===
# Address to receive x402 payments
PAY_TO_ADDRESS=0x...
# x402 Facilitator URL
FACILITATOR_URL=https://facilitator.pharos.xyz
# USDC on Pharos testnet
USDC_ADDRESS=0x...

# === MCP Server ===
MCP_PORT=3000

# === Alerts ===
# Webhook URL for security alerts (Discord, Telegram, etc.)
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
